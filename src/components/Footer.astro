---
import { SITE_TITLE } from '../consts';

const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-200 bg-white">
  <div class="mx-auto flex max-w-6xl flex-col gap-3 px-4 py-8 text-sm text-zinc-500 md:flex-row md:items-center md:justify-between md:px-6">
    <p>© {year} {SITE_TITLE}. All rights reserved.</p>

    <nav class="flex flex-wrap items-center gap-4">
      <a href="/" class="hover:text-zinc-900">Home</a>
      <a href="/blog/" class="hover:text-zinc-900">Blog</a>
      <a href="/tags/" class="hover:text-zinc-900">Tags</a>
      <a href="/about/" class="hover:text-zinc-900">About</a>
    </nav>
  </div>
</footer>
