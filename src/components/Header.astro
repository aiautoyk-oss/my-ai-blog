---
import { SITE_TITLE } from '../consts';

const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog/', label: 'Blog' },
  { href: '/tags/', label: 'Tags' },
  { href: '/about/', label: 'About' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href);
}
---

<header class="border-b border-zinc-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 md:px-6">
    <a href="/" class="text-lg font-extrabold tracking-tight text-zinc-900">
      {SITE_TITLE}
    </a>

    <nav aria-label="グローバルナビゲーション" class="flex items-center gap-5 text-sm font-medium">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`transition ${
            isActive(item.href)
              ? 'text-zinc-900 underline decoration-2 underline-offset-8'
              : 'text-zinc-500 hover:text-zinc-900'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
