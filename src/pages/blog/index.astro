---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { tagToSlug } from '../../utils/tag';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    const normalized = tag.trim();
    if (!normalized) continue;
    tagCounts.set(normalized, (tagCounts.get(normalized) ?? 0) + 1);
  }
}

const popularTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], 'ja'))
  .slice(0, 12);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={`Blog | ${SITE_TITLE}`}
      description="AIツール、ガジェット、自動化に関する記事一覧です。比較レビュー、導入ガイド、タグ絞り込みに対応しています。"
    />
  </head>

  <body class="bg-zinc-50 text-zinc-900 antialiased">
    <Header />

    <main>
      <!-- Hero / Intro -->
      <section class="border-b border-zinc-200 bg-gradient-to-b from-white via-white to-zinc-50">
        <div class="mx-auto max-w-6xl px-4 py-12 md:px-6 md:py-16">
          <div class="rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm md:p-8">
            <p class="text-sm font-semibold tracking-wide text-blue-700">Blog archive</p>
            <h1 class="mt-2 text-3xl font-black tracking-tight text-zinc-900 md:text-5xl">
              記事一覧
            </h1>
            <p class="mt-4 max-w-3xl text-sm leading-8 text-zinc-600 md:text-base">
              AIツール比較、ガジェットレビュー、自動化ノウハウを新しい順にまとめています。
              気になるテーマがあればタグから絞り込み、関連する記事をまとめて読むこともできます。
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a
                href="/tags/"
                class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-5 py-3 text-sm font-bold text-white shadow-md transition hover:bg-blue-700 hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-blue-200"
              >
                タグから探す
              </a>

              <a
                href="/about/"
                class="inline-flex items-center justify-center rounded-xl border border-zinc-300 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 shadow-sm transition hover:border-zinc-900 hover:bg-zinc-50 hover:text-zinc-900 focus:outline-none focus:ring-4 focus:ring-zinc-200"
              >
                このブログについて
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Popular tags -->
      <section class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-12">
        <div class="rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm md:p-8">
          <div class="mb-6">
            <p class="text-sm font-semibold tracking-wide text-blue-700">Browse by tag</p>
            <h2 class="mt-1 text-3xl font-black tracking-tight text-zinc-900">
              人気タグ
            </h2>
            <p class="mt-3 max-w-2xl text-sm leading-7 text-zinc-600 md:text-base">
              よく使われるテーマから、読みたい記事にすぐ移動できます。
            </p>
          </div>

          {popularTags.length === 0 ? (
            <div class="rounded-2xl border border-dashed border-zinc-300 bg-zinc-50 p-6 text-zinc-500">
              タグ付きの記事がまだありません。
            </div>
          ) : (
            <div class="flex flex-wrap gap-3">
              {popularTags.map(([tag, count]) => (
                <a
                  href={`/tags/${tagToSlug(tag)}/`}
                  class="inline-flex items-center rounded-full border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-700 shadow-sm transition hover:border-blue-300 hover:bg-blue-50 hover:text-blue-700"
                >
                  #{tag}
                  <span class="ml-2 text-zinc-400">({count})</span>
                </a>
              ))}
            </div>
          )}
        </div>
      </section>

      <!-- Posts -->
      <section class="mx-auto max-w-6xl px-4 pb-14 md:px-6 md:pb-16">
        <div class="mb-8">
          <p class="text-sm font-semibold tracking-wide text-blue-700">All posts</p>
          <h2 class="mt-1 text-3xl font-black tracking-tight text-zinc-900">
            すべての記事
          </h2>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-zinc-600 md:text-base">
            公開済みの記事を一覧で表示しています。新しい記事ほど上に表示されます。
          </p>
        </div>

        {posts.length === 0 ? (
          <div class="rounded-3xl border border-dashed border-zinc-300 bg-white p-8 shadow-sm md:p-10">
            <div class="flex flex-col gap-3">
              <p class="text-sm font-semibold text-zinc-500">No posts yet</p>
              <h3 class="text-xl font-bold text-zinc-900">まだ記事がありません</h3>
              <p class="max-w-2xl text-sm leading-7 text-zinc-600 md:text-base">
                記事生成を実行すると、ここにブログ記事が一覧表示されます。
              </p>
              <div class="mt-2 flex flex-wrap gap-3">
                <a
                  href="/"
                  class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-5 py-3 text-sm font-bold text-white shadow-md transition hover:bg-blue-700 hover:shadow-lg"
                >
                  トップへ戻る
                </a>
                <a
                  href="/tags/"
                  class="inline-flex items-center justify-center rounded-xl border border-zinc-300 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 shadow-sm transition hover:border-zinc-900 hover:text-zinc-900"
                >
                  タグ一覧を見る
                </a>
              </div>
            </div>
          </div>
        ) : (
          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {posts.map((post) => (
              <article class="overflow-hidden rounded-3xl border border-zinc-200 bg-white shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-md">
                {post.data.heroImage && (
                  <a href={`/blog/${post.id}/`} class="block">
                    <img
                      src={post.data.heroImage}
                      alt={post.data.title}
                      class="h-52 w-full object-cover"
                      loading="lazy"
                    />
                  </a>
                )}

                <div class="p-5 md:p-6">
                  <div class="mb-3 text-xs font-medium text-zinc-500">
                    <FormattedDate date={post.data.pubDate} />
                  </div>

                  <h3 class="text-xl font-extrabold leading-8 tracking-tight text-zinc-900">
                    <a href={`/blog/${post.id}/`} class="transition hover:text-blue-700">
                      {post.data.title}
                    </a>
                  </h3>

                  <p class="mt-3 text-sm leading-7 text-zinc-600">
                    {post.data.description}
                  </p>

                  {(post.data.tags?.length ?? 0) > 0 && (
                    <ul class="mt-4 flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <li>
                          <a
                            href={`/tags/${tagToSlug(tag)}/`}
                            class="inline-flex items-center rounded-full bg-zinc-100 px-3 py-1 text-xs font-semibold text-zinc-700 transition hover:bg-zinc-900 hover:text-white"
                          >
                            #{tag}
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </article>
            ))}
          </div>
        )}
      </section>
    </main>

    <Footer />
  </body>
</html>
