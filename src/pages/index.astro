---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';
import { tagToSlug } from '../utils/tag';

const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = allPosts.slice(0, 6);

const tagCounts = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags ?? []) {
    const normalized = tag.trim();
    if (!normalized) continue;
    tagCounts.set(normalized, (tagCounts.get(normalized) ?? 0) + 1);
  }
}

const popularTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], 'ja'))
  .slice(0, 12);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={`${SITE_TITLE} | AIツール・ガジェット・自動化の実用ブログ`}
      description="AIツール比較、ガジェットレビュー、自動化ノウハウを実用目線で整理するブログ。初心者でも比較しやすいように、特徴・注意点・選び方をわかりやすくまとめています。"
    />
  </head>

  <body class="bg-zinc-50 text-zinc-900 antialiased">
    <Header />

    <main>
      <!-- Hero -->
      <section class="border-b border-zinc-200 bg-gradient-to-b from-white via-white to-zinc-50">
        <div class="mx-auto grid max-w-6xl gap-8 px-4 py-14 md:grid-cols-[1.15fr_0.85fr] md:px-6 md:py-20 lg:gap-12">
          <div class="flex flex-col justify-center">
            <div class="mb-5">
              <span class="inline-flex items-center rounded-full border border-blue-200 bg-blue-50 px-3 py-1 text-xs font-bold tracking-wide text-blue-700">
                AI / ガジェット / 自動化
              </span>
            </div>

            <h1 class="max-w-3xl text-4xl font-black leading-tight tracking-tight text-zinc-900 md:text-5xl">
              AIツールとガジェットを、
              <br class="hidden md:block" />
              “実際に使う目線”で
              <br class="hidden md:block" />
              比較するブログ
            </h1>

            <p class="mt-6 max-w-2xl text-base leading-8 text-zinc-600 md:text-lg">
              ChatGPT・Gemini・Claude などの AI ツール比較、
              生産性を上げるガジェット、
              自動化に役立つサービスを、
              「何ができるか」「どんな人に向くか」「どこに注意すべきか」の視点で、
              実用的に整理して紹介します。
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a
                href="/blog/"
                class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-6 py-3.5 text-sm font-bold text-white shadow-md transition hover:bg-blue-700 hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-blue-200"
              >
                最新記事を見る
              </a>

              <a
                href="/tags/"
                class="inline-flex items-center justify-center rounded-xl border border-zinc-300 bg-white px-6 py-3.5 text-sm font-semibold text-zinc-700 shadow-sm transition hover:border-zinc-900 hover:bg-zinc-50 hover:text-zinc-900 focus:outline-none focus:ring-4 focus:ring-zinc-200"
              >
                タグから探す
              </a>
            </div>

            <div class="mt-8 flex flex-wrap gap-3 text-sm text-zinc-500">
              <span class="rounded-full bg-white px-3 py-1.5 shadow-sm ring-1 ring-zinc-200">比較レビュー</span>
              <span class="rounded-full bg-white px-3 py-1.5 shadow-sm ring-1 ring-zinc-200">導入ガイド</span>
              <span class="rounded-full bg-white px-3 py-1.5 shadow-sm ring-1 ring-zinc-200">作業効率化</span>
            </div>
          </div>

          <div class="flex items-center">
            <div class="w-full rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm md:p-8">
              <div class="mb-5 flex items-center gap-3">
                <div class="h-10 w-10 rounded-2xl bg-blue-50 text-center text-lg leading-10 text-blue-700">
                  ✓
                </div>
                <div>
                  <p class="text-sm font-semibold text-zinc-500">Guide</p>
                  <h2 class="text-xl font-extrabold tracking-tight text-zinc-900">
                    このブログで読める内容
                  </h2>
                </div>
              </div>

              <ul class="space-y-5 text-sm leading-7 text-zinc-600">
                <li>
                  <strong class="block text-base text-zinc-900">AIツール比較</strong>
                  機能差・料金・向いている用途を整理
                </li>
                <li>
                  <strong class="block text-base text-zinc-900">ガジェットレビュー</strong>
                  仕事や日常で使いやすい製品を実用目線で紹介
                </li>
                <li>
                  <strong class="block text-base text-zinc-900">自動化ノウハウ</strong>
                  作業削減や効率化につながる使い方を解説
                </li>
                <li>
                  <strong class="block text-base text-zinc-900">選び方の整理</strong>
                  初心者でも比較しやすいように要点を明確化
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- Latest posts -->
      <section class="mx-auto max-w-6xl px-4 py-12 md:px-6 md:py-14">
        <div class="mb-8 flex items-end justify-between gap-4">
          <div>
            <p class="text-sm font-semibold tracking-wide text-blue-700">Latest posts</p>
            <h2 class="mt-1 text-3xl font-black tracking-tight text-zinc-900">
              最新記事
            </h2>
            <p class="mt-3 max-w-2xl text-sm leading-7 text-zinc-600 md:text-base">
              新しく公開された記事をまとめて確認できます。
            </p>
          </div>

          <a
            href="/blog/"
            class="hidden rounded-xl border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-700 shadow-sm transition hover:border-zinc-900 hover:text-zinc-900 md:inline-flex"
          >
            すべて見る →
          </a>
        </div>

        {latestPosts.length === 0 ? (
          <div class="rounded-3xl border border-dashed border-zinc-300 bg-white p-8 shadow-sm md:p-10">
            <div class="flex flex-col gap-3">
              <p class="text-sm font-semibold text-zinc-500">No posts yet</p>
              <h3 class="text-xl font-bold text-zinc-900">まだ記事がありません</h3>
              <p class="max-w-2xl text-sm leading-7 text-zinc-600 md:text-base">
                記事生成を実行すると、ここに最新記事がカード形式で表示されます。
              </p>
              <div class="mt-2">
                <a
                  href="/blog/"
                  class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-5 py-3 text-sm font-bold text-white shadow-md transition hover:bg-blue-700 hover:shadow-lg"
                >
                  ブログ一覧へ
                </a>
              </div>
            </div>
          </div>
        ) : (
          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {latestPosts.map((post) => (
              <article class="overflow-hidden rounded-3xl border border-zinc-200 bg-white shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-md">
                {post.data.heroImage && (
                  <a href={`/blog/${post.id}/`} class="block">
                    <img
                      src={post.data.heroImage}
                      alt={post.data.title}
                      class="h-52 w-full object-cover"
                      loading="lazy"
                    />
                  </a>
                )}

                <div class="p-5 md:p-6">
                  <div class="mb-3 text-xs font-medium text-zinc-500">
                    <FormattedDate date={post.data.pubDate} />
                  </div>

                  <h3 class="text-xl font-extrabold leading-8 tracking-tight text-zinc-900">
                    <a href={`/blog/${post.id}/`} class="transition hover:text-blue-700">
                      {post.data.title}
                    </a>
                  </h3>

                  <p class="mt-3 text-sm leading-7 text-zinc-600">
                    {post.data.description}
                  </p>

                  {(post.data.tags?.length ?? 0) > 0 && (
                    <ul class="mt-4 flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <li>
                          <a
                            href={`/tags/${tagToSlug(tag)}/`}
                            class="inline-flex items-center rounded-full bg-zinc-100 px-3 py-1 text-xs font-semibold text-zinc-700 transition hover:bg-zinc-900 hover:text-white"
                          >
                            #{tag}
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </article>
            ))}
          </div>
        )}

        <div class="mt-6 md:hidden">
          <a
            href="/blog/"
            class="inline-flex rounded-xl border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-700 shadow-sm transition hover:border-zinc-900 hover:text-zinc-900"
          >
            すべて見る →
          </a>
        </div>
      </section>

      <!-- Browse by tag -->
      <section class="mx-auto max-w-6xl px-4 pb-14 md:px-6 md:pb-16">
        <div class="rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm md:p-8">
          <div class="mb-6">
            <p class="text-sm font-semibold tracking-wide text-blue-700">Browse by tag</p>
            <h2 class="mt-1 text-3xl font-black tracking-tight text-zinc-900">
              タグから探す
            </h2>
            <p class="mt-3 max-w-2xl text-sm leading-7 text-zinc-600 md:text-base">
              気になるテーマをクリックすると、そのタグに関連する記事だけを一覧表示できます。
            </p>
          </div>

          {popularTags.length === 0 ? (
            <div class="rounded-2xl border border-dashed border-zinc-300 bg-zinc-50 p-6 text-zinc-500">
              タグ付きの記事がまだありません。
            </div>
          ) : (
            <div class="flex flex-wrap gap-3">
              {popularTags.map(([tag, count]) => (
                <a
                  href={`/tags/${tagToSlug(tag)}/`}
                  class="inline-flex items-center rounded-full border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-700 shadow-sm transition hover:border-blue-300 hover:bg-blue-50 hover:text-blue-700"
                >
                  #{tag}
                  <span class="ml-2 text-zinc-400">({count})</span>
                </a>
              ))}
            </div>
          )}
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
