---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { tagToSlug } from '../../utils/tag';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft);

const tagCounts = new Map<string, number>();

for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    const normalized = tag.trim();
    if (!normalized) continue;
    tagCounts.set(normalized, (tagCounts.get(normalized) ?? 0) + 1);
  }
}

const tags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], 'ja'));
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={`Tags | ${SITE_TITLE}`}
      description="ブログ内のタグ一覧です。気になるテーマごとに記事を絞り込めます。"
    />
  </head>

  <body class="bg-zinc-50 text-zinc-900 antialiased">
    <Header />

    <main class="mx-auto max-w-5xl px-4 py-10 md:px-6 md:py-14">
      <div class="rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm md:p-8">
        <div class="mb-8">
          <p class="text-sm font-semibold tracking-wide text-blue-700">Tag archive</p>
          <h1 class="mt-1 text-3xl font-black tracking-tight text-zinc-900 md:text-4xl">
            タグ一覧
          </h1>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-zinc-600 md:text-base">
            気になるテーマをクリックすると、そのタグを含む記事だけを一覧表示できます。
          </p>
        </div>

        {tags.length === 0 ? (
          <div class="rounded-2xl border border-dashed border-zinc-300 bg-zinc-50 p-8 text-zinc-500">
            タグ付きの記事がまだありません。
          </div>
        ) : (
          <div class="flex flex-wrap gap-3">
            {tags.map(([tag, count]) => (
              <a
                href={`/tags/${tagToSlug(tag)}/`}
                class="inline-flex items-center rounded-full border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-700 shadow-sm transition hover:border-blue-300 hover:bg-blue-50 hover:text-blue-700"
              >
                #{tag}
                <span class="ml-2 text-zinc-400">({count})</span>
              </a>
            ))}
          </div>
        )}
      </div>
    </main>

    <Footer />
  </body>
</html>
